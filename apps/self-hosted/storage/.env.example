# 🌐 Server
PORT=3005                  # Port chạy server backend
CLEANER_KEY_ID=your_sign_secret_here   # Secret cho việc ký request nội bộ

# ☁️ Cloudflare R2 Storage
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com   # Endpoint R2 (dạng https://xxx.r2.cloudflarestorage.com)
R2_ACCESS_KEY=your_r2_access_key     # Access Key để kết nối R2
R2_SECRET_KEY=your_r2_secret_key     # Secret Key đi kèm Access Key
R2_BUCKET=your_bucket_name           # Tên bucket R2 để lưu file (vd: locket-media)

# 🔑 Internal Services
CLEANER_KEY_ID=your_cleaner_key_id   # Key ID cho job dọn dẹp (background worker)

# 📡 External APIs
MEDIA_API_URL=https://media.your-domain.com   # URL API cho media service (upload / resize ảnh, video...)
